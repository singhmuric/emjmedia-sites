# Dependencies
node_modules/
yarn.lock
pnpm-lock.yaml
# package-lock.json is committed per plan §2.1 (reproducible builds)

# Secrets & Environment
.env
.env.*
!.env.example
*.pem
*.key
secrets/
*.secret
credentials.json

# Build artifacts
dist/
build/
.next/
.vercel/
.cache/
out/

# Logs (runtime). _logs/ ist Teil des Repos (Ordner-Skelett mit .gitkeep),
# aber Build-/Lighthouse-Reports sind ephemer und werden NICHT committed.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
_logs/builds/*
!_logs/builds/.gitkeep
!_logs/builds/*.md
_logs/lighthouse/*
!_logs/lighthouse/.gitkeep
!_logs/lighthouse/*.md

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Claude Code lokale State-Files (falls welche entstehen)
.claude/state/
.claude/cache/
.claude/local/

# Temp
tmp/
temp/
*.tmp
