  "filiale_patterns": [
    {
      "id": "gmbh-stadt-suffix",
      "regex_source": "\\bGmbH\\s+[A-ZÄÖÜ][a-zäöüß]+(\\s*-\\s*[A-ZÄÖÜ][a-zäöüß]+)+",
      "flags": "",
      "match_field": "name",
      "weight": -10,
      "comment": "GmbH gefolgt von 'Stadt-Stadtteil', z.B. 'Carglass GmbH Hamburg-Stellingen' — nur Name (Address hat fast immer GmbH+Stadt)"
    },
    {
      "id": "filiale-marker",
      "regex_source": "\\b(Filiale|Standort|Niederlassung|Service-Point|Service-Center|Servicecenter)\\b",
      "flags": "i",
      "match_field": "name",
      "weight": -10,
      "comment": "Explizite Filial-Marker im Namen — nur Name (Strassennamen können 'Standort' enthalten)"
    },
    {
      "id": "ehemals-prefix",
      "regex_source": "\\(\\s*ehemals\\s+",
      "flags": "i",
      "match_field": "name",
      "weight": -10,
      "comment": "Übernommene Filiale wird als '(ehemals X)' gelistet"
    },
    {
      "id": "plz-stadt-suffix",
      "regex_source": "\\b\\d{4,5}\\s+(Hamburg|Lübeck|Kiel|Flensburg|Neumünster|Husum|Schleswig|Itzehoe|Pinneberg|Norderstedt)\\b",
      "flags": "i",
      "match_field": "name",
      "weight": -10,
      "comment": "PLZ + SH-Stadt im Namen → fast immer Filiale-Branding. Nur Name (Address hat IMMER PLZ+Stadt)"
    }
  ],
  "score_rules": {
    "block_list_match": "hard_dq",
    "single_pattern_match": -10,
    "multi_pattern_match": -20,
    "comment": "block_list_match → Lead komplett verwerfen (NICHT scored, NICHT appendet). Pattern-Matches optional als Soft-Penalty wenn Score-Calc-Stage. Pre-Filter implementiert nur block_list_match."
  },
